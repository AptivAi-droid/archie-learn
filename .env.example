# ─── Supabase (frontend — safe to expose) ───────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Anthropic (server-side only — NEVER expose to client) ──────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Netlify function environment (set in Netlify dashboard, not .env) ───────
# These are server-side copies of the Supabase vars used inside Netlify functions
# for rate limiting. Set them in Netlify → Site settings → Environment variables.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Optional overrides ──────────────────────────────────────────────────────
# VITE_CHAT_API_URL=http://localhost:3001/api/chat   # local dev server
# VITE_MARK_API_URL=http://localhost:3001/api/mark
# CHAT_RATE_LIMIT=30                                 # requests per user per hour (default: 30)
# ALLOWED_ORIGIN=https://your-domain.netlify.app     # restrict CORS to your domain

# ─── Google OAuth (configure in Supabase Auth dashboard first) ───────────────
# No extra env vars needed — Google OAuth is configured in the Supabase dashboard
# and uses VITE_SUPABASE_URL automatically.
